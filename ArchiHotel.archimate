<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="ArchiHotel Enterprise Architecture" id="id-32256d07a6ad432d90fecd639e316e34" version="5.0.0">
  <folder name="Strategy" id="id-4483d73bd60e4e118e47395b78b8daab" type="strategy"/>
  <folder name="Business" id="id-74cf1db50ecb43a5b4542eb675282342" type="business">
    <element xsi:type="archimate:BusinessActor" name="Guest" id="id-ed24ecca05804aa384d7cf38a9756a2a">
      <documentation>Hotel guest who accesses rooms and facilities using their key card.</documentation>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Receptionist" id="id-71ccde526cfe485885308cd24d2fb784">
      <documentation>Front desk staff who issues and configures key cards at check-in.</documentation>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Housekeeping Staff" id="id-093c653833c74ed38c783659f1845f4f">
      <documentation>Hotel staff with authorized key cards to enter rooms for cleaning and maintenance.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Room Access Service" id="id-5bda12192d0548b1a3b01917ed7fb605">
      <documentation>Provides secure, controlled access to guest rooms and authorized facilities via key card verification.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Key Card Issuance Service" id="id-8890b1e063f74ae2b563d166df9f36f2">
      <documentation>Issues and configures a key card with access rights at guest check-in.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Check-in &amp; Issue Key Card" id="id-2bdb2ad08697435988ce894c68db310f">
      <documentation>Receptionist processes guest check-in in the HMS, then issues and configures a key card with room and facility access rights.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Access Room" id="id-6997406b22ee4718ae93075b65f46a37">
      <documentation>Guest presents key card to door reader; system verifies access rights and unlocks the door if authorized.</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Key Card" id="id-676c240fe82f4585bbc35bb53033ce49">
      <documentation>Physical RFID card issued to guests and staff, carrying access rights for rooms and facilities.</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Access Rights" id="id-f98fa8eee46940c3914d7738d7829736">
      <documentation>Digital permissions stored on the key card and in the HMS, defining which rooms and areas the card holder may enter.</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Guest Reservation" id="id-91b78b79b5a34949abda58e5a21f6702">
      <documentation>Approved reservation record containing guest identity, room assignment, and stay details.</documentation>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Hotel Manager" id="id-21c8b5ad9820470ea4d96317d14387dd">
      <documentation>Leads the daily morning briefing. Responsible for operational coordination across all departments.</documentation>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Head of Concierge" id="id-4833d0eaca604546bc4e9c310639b5ac">
      <documentation>Attends the daily briefing and coordinates concierge team assignments and VIP handling.</documentation>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Head of Housekeeping" id="id-dc91b088f5b44a0588240055ab6a5ea3">
      <documentation>Attends the daily briefing and aligns housekeeping priorities for the day.</documentation>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Hotel Staff" id="id-f1bd9deed09d474b95553628fdb07846">
      <documentation>All operational staff (reception, concierge, housekeeping, service teams) who consume briefing updates via the Staff Portal.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Daily Operational Briefing Service" id="id-a1a0e207b3744b29bb09f9e3d0830359">
      <documentation>Service that delivers a shared, real-time operational picture to all departments every morning before arrivals begin.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Generate Briefing Report" id="id-bda1cacc32a14367acc8869f57086e3d">
      <documentation>HMS automatically assembles the Arrival Schedule, VIP List, special requests, and operational updates into the Briefing Report each morning.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Conduct Briefing Meeting" id="id-c2b63735527b43b699ff4272a68bfcc8">
      <documentation>Hotel Manager, Head of Concierge, and Head of Housekeeping review the Briefing Report, align on VIPs, cross-dept tasks, and staffing priorities.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Broadcast Coordination" id="id-24c83336cc4a4576b554eca11bc12dd8">
      <documentation>Agreed priorities and task assignments are pushed to all staff Android phones via the Staff Portal app.</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Arrival Schedule" id="id-74cb35a92d9c412fa666eecc831e06fd">
      <documentation>List of all expected guest arrivals for the day, including room assignments, times, and guest details.</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="VIP List" id="id-806c62e974f1475784f1cddc03aba174">
      <documentation>Curated list of high-value arriving guests with their special requests (airport transfer, champagne, late check-out, etc.).</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Briefing Report" id="id-9afa90ca47964ec2b246955d8c14e932">
      <documentation>Daily operational document consolidating arrivals, VIP list, transfers, housekeeping tasks, and cross-departmental coordination notes.</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Special Request" id="id-f92cd7a29c3541ecb8adc4be99824c59">
      <documentation>Guest-submitted request (in-room preparation, transfer, VIP service) that requires cross-department coordination.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Online Booking Service" id="id-a3cde20e5b224e5bbc6187ad0e0f3905"/>
    <element xsi:type="archimate:BusinessService" name="Check-in &amp; Key Card Service" id="id-edbd094de1154cc294dc6e8284dcadda"/>
    <element xsi:type="archimate:BusinessService" name="Laundry Access Service" id="id-1708a5155c454839b0364f0685f1e4a3"/>
    <element xsi:type="archimate:BusinessService" name="Airport Transfer Service" id="id-f1adfae0d8454b6490b864869aa43075"/>
    <element xsi:type="archimate:BusinessActor" name="Hotel Guest" id="id-bd79805478984427aca6ebf0e4e22003"/>
    <element xsi:type="archimate:BusinessActor" name="Front Desk Staff" id="id-2e7dd08ccf7147c992527c2439fd7c94"/>
    <element xsi:type="archimate:BusinessProcess" name="Present Key Card" id="id-0fe4c5c7d2e744ac87e3219d1dba9ec3"/>
    <element xsi:type="archimate:BusinessProcess" name="Enter Room" id="id-a9233dcf6ffa4cbd82ecfc69a138c7a2"/>
    <element xsi:type="archimate:BusinessEvent" name="Access Denied" id="id-b27561a2354a4e2082a793863293828d"/>
    <element xsi:type="archimate:BusinessProcess" name="Configure Key Card" id="id-e56d620d91d24ce98c1b108a649e329c"/>
    <element xsi:type="archimate:BusinessProcess" name="Daily Briefing Process" id="id-0fc90cb6160a45e89962a39037968a8d"/>
  </folder>
  <folder name="Application" id="id-f87c2d4882b140e79f282cbf04df0996" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="Hotel Management System" id="id-864ff71135f34424ab79ef07d7528e0b">
      <documentation>Central system managing reservations, guest profiles, room status, key card configuration, and open costs. Hosted on AWS.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Door System Software" id="id-6b25986d097b40e39084e7791f298b9f">
      <documentation>Software that verifies RFID key card access rights and controls door lock/unlock decisions.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Energy Management System" id="id-85707d8b4e5d4764b9f07a9a19895f3f">
      <documentation>System that activates the room electrical circuit when a valid key card is inserted in the card switch.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Key Card Configuration Service" id="id-979c4999c296463eb121cbe9eaa9e694">
      <documentation>Application service within the HMS that assigns and stores access rights on a key card at check-in.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Access Verification Service" id="id-013ac29141a546f08a286516693f9a06">
      <documentation>Application service within Door System Software that validates RFID card credentials and issues unlock/deny decision.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Energy Activation Service" id="id-1ddf91ce404840c98ec398cb6fb2a6a3">
      <documentation>Application service that activates or deactivates the room electrical circuit based on card-switch state.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Access Rights Record" id="id-95fa9cda34b14b84b8ec1f311e15edb3">
      <documentation>Digital record of permissions per key card: which rooms and service areas are accessible and for which period.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Card Credential" id="id-161db4eead9941ba81e0dde8b05f8f42">
      <documentation>RFID credential data transmitted by the key card to the door reader for verification.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Room Power State" id="id-6770f34a7efe49049a626f6b0796ff72">
      <documentation>Current on/off state of the room electrical circuit, driven by the energy saver card switch.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Staff Portal" id="id-6a04feb19a1e4a6eb95ef09b587235ac">
      <documentation>Android app installed on staff smartphones. Delivers push notifications, operational dashboard, briefing reports, task lists, and schedules to all hotel staff.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Briefing Report Generation Service" id="id-43d91a2ce66942238382b8195e31983f">
      <documentation>HMS service that automatically assembles the daily Briefing Report from reservation, VIP, transfer, and special request data each morning.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Push Notification Service" id="id-8e5f37cfeaaf417a9d18e3f7d368d03d">
      <documentation>Service within the Staff Portal that broadcasts urgent updates, task assignments, and coordination messages to staff Android devices.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Operational Dashboard Service" id="id-3ec3d617f6a14e52bd64f01c8ffdd31a">
      <documentation>Service within the Staff Portal that renders a real-time dashboard combining arrivals, VIP list, housekeeping tasks, and briefing info.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Briefing Report Data" id="id-13c2e1df4a8f4b46aca7a53f048bad75">
      <documentation>Structured digital document: arrivals count, VIP list, transfer schedule, housekeeping todos, and cross-dept coordination tasks.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Arrival Schedule Data" id="id-0e97ce796cfe405181cd325c0b6506dc">
      <documentation>Machine-readable arrival list synchronized to staff devices from the HMS each morning.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Task Assignment Data" id="id-96fca4fb3305458abe0631967a2f7efb">
      <documentation>Housekeeping and coordination task records distributed to staff via the Staff Portal.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Booking Engine" id="id-bc171e615f664d5cb5a215c0e329a453"/>
    <element xsi:type="archimate:ApplicationComponent" name="Laundry Management System" id="id-4650df174169450ca4560f970b148d4c"/>
    <element xsi:type="archimate:ApplicationComponent" name="Transfer Coordination App" id="id-2d1b81da1ff64f919b386f3350277f6f"/>
    <element xsi:type="archimate:ApplicationFunction" name="Validate Access Rights" id="id-3439441556d0415ba8b55899438b238d"/>
    <element xsi:type="archimate:ApplicationFunction" name="Compile Briefing Data" id="id-ae97a27635f843b19586bc377744b0a1"/>
    <element xsi:type="archimate:ApplicationFunction" name="Send Push Notification" id="id-d002778e80a143578d7d587702d138fc"/>
  </folder>
  <folder name="Technology &amp; Physical" id="id-e5568415aa254b72a4f2a35c40925b0e" type="technology">
    <element xsi:type="archimate:Node" name="AWS Cloud Server" id="id-d10ac3a5c1994db4bf423ae53ed5b166">
      <documentation>Central cloud server on Amazon Web Services hosting the Hotel Management System and storing guest data, reservations, and access rights.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Door Card Reader" id="id-5b16aa7465624d50b63a8b7eb911b620">
      <documentation>Physical RFID reader mounted on each room door that reads the key card credential and triggers the Door System Software verification.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Energy Saver Interface" id="id-34cae57b1c8a4617b38e2ccdce1b4ef3">
      <documentation>In-room card switch device: when a valid key card is inserted, it activates the room electrical circuit; removal cuts power to save energy.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Reception PC &amp; Terminal" id="id-6fd544eb67374a92b3c189363c54403b">
      <documentation>Receptionist workstation (PC + payment terminal) used to process check-in and configure key cards in the HMS.</documentation>
    </element>
    <element xsi:type="archimate:CommunicationNetwork" name="Hotel Wi-Fi Network" id="id-fc006e4ca7034e94803383e4fe15d058">
      <documentation>Internal wireless network connecting all devices, workstations, and applications across the hotel for real-time data synchronization.</documentation>
    </element>
    <element xsi:type="archimate:CommunicationNetwork" name="RFID Communication" id="id-cb02ec8f4ae0425c929b3df4fd176fba">
      <documentation>Short-range RFID wireless protocol used by the key card and door card reader to transmit access credentials securely.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Door System Software Runtime" id="id-814fd201c952441bb0f6b7487bd990a1">
      <documentation>Runtime environment for the Door System Software; deployed on the door card reader infrastructure.</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="Access Rights Data Store" id="id-e644e39b05094b88bdd6d886e4f85d7d">
      <documentation>Persistent storage of key card access rights records on the AWS server, read by Door System Software during verification.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Android Smartphone" id="id-489624fe9ac84915ae683659fa943010">
      <documentation>Staff-issued Android device running the Staff Portal app, receiving push notifications and displaying the operational dashboard.</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="Briefing Report File" id="id-4a9eec472670415085cfc7e40aef4b7e">
      <documentation>Daily generated report artifact stored on the AWS server and synchronized to staff devices via Wi-Fi.</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="Task Assignment Store" id="id-48a63062e8134563ac6ea35fe95cc683">
      <documentation>Persistent storage of housekeeping and coordination task records on the AWS server.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="Hotel On-Premise Server" id="id-c5412f52b0dd41febef7b0ada1ef2ef1"/>
    <element xsi:type="archimate:Node" name="Door Control Node" id="id-a7f28492fdba41d7add451878ab71130"/>
    <element xsi:type="archimate:TechnologyFunction" name="Card Reading" id="id-fa41fb00430944f2b99ebc4d0bce3d6a"/>
    <element xsi:type="archimate:TechnologyService" name="Card Reading Service" id="id-127d8c1f3ad249dc81aef52539aecf8f"/>
    <element xsi:type="archimate:TechnologyService" name="Wi-Fi Sync Service" id="id-68740240cac845b4afda8540689dc019"/>
  </folder>
